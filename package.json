{
  "name": "dc-metro-mate",
  "version": "0.1.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "api:dev": "node scripts/local-api-server.mjs",
    "api:dev:worker": "wrangler dev --config worker/wrangler.jsonc --local --port 8787",
    "api:types": "wrangler types --config worker/wrangler.jsonc worker/worker-configuration.d.ts",
    "start": "expo start",
    "start:dev": "APP_ENV=development expo start",
    "start:staging": "APP_ENV=staging expo start",
    "start:prod": "APP_ENV=production expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "expo": "54.0.25",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.10",
    "expo-file-system": "~19.0.23",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@expo/cli": "54.0.25",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~6.0.3",
    "wrangler": "^4.105.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
